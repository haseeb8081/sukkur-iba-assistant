# Environment Variables

# Supabase Credentials (obtain from your Supabase project settings)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Groq API Key (obtain from console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Embedding Model (Optional if using open source embedder)
OPENAI_API_KEY=your_openai_api_key_if_using_openai_embeddings
